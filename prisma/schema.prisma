generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SavedSearch {
  id                 String   @id @default(cuid())
  name               String
  origin             String
  destination        String
  departDate         DateTime
  returnDate         DateTime?
  tripType           String
  passengers         Int
  cabin              String
  nearbyAirports     Boolean  @default(false)
  mixAndMatchEnabled Boolean  @default(true)
  regionalMarket     String
  displayCurrency    String
  createdAt          DateTime @default(now())
}

model PriceAlert {
  id              String   @id @default(cuid())
  routeLabel      String
  origin          String
  destination     String
  departDate      DateTime
  returnDate      DateTime?
  tripType        String
  email           String
  targetPrice     Int
  currency        String
  regionalMarket  String
  lastTrackedPrice Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}
